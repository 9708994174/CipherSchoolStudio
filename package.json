{
  "name": "cipher-sql-studio",
  "version": "1.0.0",
  "description": "A browser-based SQL learning platform",
  "main": "server/index.js",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "npm run dev --workspace=server",
    "client": "npm run start --workspace=client",
    "install-all": "npm install",
    "build": "CI=false npm run build --workspace=client",
    "vercel-build": "npm run build",
    "start": "npm run start --workspace=server"
  },
  "keywords": [
    "sql",
    "learning",
    "education"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}